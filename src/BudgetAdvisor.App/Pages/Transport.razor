    private async Task HandleAddCostAsync()
    {
        var date = DateOnly.FromDateTime(costForm.Date!.Value);
        await AppState.AddOneTimeExpenseAsync(
            costForm.Amount,
            date.Year,
            date.Month,
            ExpenseCategory.Transport,
            costForm.Subcategory,
            costForm.Description,
            transportVehicleId: costForm.VehicleId);

        costForm = new TransportCostFormModel();
        ResetForms();
        statusMessage = Localizer["transport.costAdded"];
    }

    private async Task HandleAddDefinitionAsync()
    {
        var startDate = DateOnly.FromDateTime(definitionForm.StartDate!.Value);
        var endDate = DateOnly.FromDateTime(definitionForm.EndDate!.Value);
        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        await AppState.AddTransportDefinitionAsync(
            definitionForm.Amount,
            definitionForm.IntervalMonths,
            startDate.Year,
            startDate.Month,
            endDate.Year,
            endDate.Month,
            definitionForm.Subcategory,
            definitionForm.VehicleId!.Value);

        definitionForm = new TransportDefinitionFormModel();
        ResetForms();
        statusMessage = Localizer["transport.definitionAdded"];
    }

    private async Task HandleAddLoanAsync()
    {
        await AppState.AddTransportLoanAsync(
            loanForm.VehicleId!.Value,
            loanForm.Lender,
            DateOnly.FromDateTime(loanForm.LoanStartDate!.Value),
            loanForm.InitialLoanAmount,
            loanForm.RemainingDebt);

        loanForm = new TransportLoanFormModel();
        ResetForms();
        statusMessage = Localizer["transport.loanAdded"];
    }

    private async Task HandleAddBindingPeriodAsync(Guid loanId)
    {
        var form = GetBindingPeriodForm(loanId);
        var startDate = DateOnly.FromDateTime(form.StartDate!.Value);
        var endDate = DateOnly.FromDateTime(form.EndDate!.Value);

        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        try
        {
            await AppState.AddLoanInterestBindingPeriodAsync(loanId, startDate, endDate, form.InterestRate, form.MonthlyAmortization);
            bindingPeriodForms[loanId] = CreateBindingPeriodForm();
            bindingPeriodEditContexts[loanId] = new EditContext(bindingPeriodForms[loanId]);
            statusMessage = Localizer["transport.bindingPeriodAdded"];
        }
        catch (InvalidOperationException)
        {
            statusMessage = Localizer["validation.loanBindingPeriodOverlap"];
        }
    }

    private async Task HandleAddLeasingContractAsync()
    {
        var startDate = DateOnly.FromDateTime(leasingForm.StartDate!.Value);
        var endDate = DateOnly.FromDateTime(leasingForm.EndDate!.Value);
        if (endDate < startDate)
        {
            statusMessage = Localizer["validation.endDateOnOrAfterStartDate"];
            return;
        }

        try
        {
            await AppState.AddTransportLeasingContractAsync(leasingForm.VehicleId!.Value, startDate, endDate, leasingForm.MonthlyCost);
            leasingForm = new TransportLeasingFormModel();
            ResetForms();
            statusMessage = Localizer["transport.leasingContractAdded"];
        }
        catch (InvalidOperationException)
        {
            statusMessage = Localizer["validation.transportLeasingOverlap"];
        }
    }

    private async Task HandleAddVehicleAsync()
    {
        await AppState.AddTransportVehicleAsync(
            vehicleForm.Name,
            vehicleForm.ModelYear,
            vehicleForm.Mileage,
            vehicleForm.FuelType,
            vehicleForm.VehicleType,
            vehicleForm.OwnershipType,
            vehicleForm.PurchasePrice,
            vehicleForm.EstimatedSaleValue);

        vehicleForm = new TransportVehicleFormModel();
        ResetForms();
        statusMessage = Localizer["transport.vehicleAdded"];
    }

    private async Task HandleDeleteExpenseAsync(ExpenseEntry expense)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { dialog => dialog.Title, Localizer["dialog.deleteTitle"] },
            { dialog => dialog.Message, string.Format(Localizer["transport.deleteCostMessage"], AppState.GetExpenseDescriptionDisplay(expense)) },
            { dialog => dialog.ConfirmText, Localizer["action.delete"] },
            { dialog => dialog.CancelText, Localizer["action.cancel"] }
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>(Localizer["dialog.deleteTitle"], parameters);
        if (dialog is null)
        {
            return;
        }

        var result = await dialog.Result;
        if (result?.Canceled ?? true)
        {
            return;
        }

        await AppState.RemoveExpenseAsync(expense.Id);
        statusMessage = Localizer["transport.costDeleted"];
    }

