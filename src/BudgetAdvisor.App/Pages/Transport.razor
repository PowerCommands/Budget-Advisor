    private void ResetForms()
    {
        var today = DateTime.Today;
        costForm.Date ??= today;
        definitionForm.StartDate ??= new DateTime(today.Year, today.Month, 1);
        definitionForm.EndDate ??= new DateTime(today.Year, today.Month, 1);
        definitionForm.IntervalMonths = 1;
        loanForm.LoanStartDate ??= today;
        leasingForm.StartDate ??= new DateTime(today.Year, today.Month, 1);
        leasingForm.EndDate ??= new DateTime(today.Year, today.Month, 1);
        vehicleForm.ModelYear = vehicleForm.ModelYear == 0 ? today.Year : vehicleForm.ModelYear;
        vehicleForm.FuelType = vehicleForm.FuelType == 0 ? VehicleFuelType.Petrol : vehicleForm.FuelType;
        vehicleForm.VehicleType = vehicleForm.VehicleType == 0 ? TransportVehicleType.Car : vehicleForm.VehicleType;
        vehicleForm.OwnershipType = vehicleForm.OwnershipType == 0 ? VehicleOwnershipType.Private : vehicleForm.OwnershipType;

        costEditContext = new EditContext(costForm);
        definitionEditContext = new EditContext(definitionForm);
        loanEditContext = new EditContext(loanForm);
        leasingEditContext = new EditContext(leasingForm);
        vehicleEditContext = new EditContext(vehicleForm);
    }

    private LoanBindingPeriodFormModel GetBindingPeriodForm(Guid loanId)
    {
        EnsureLoanForms(loanId);
        return bindingPeriodForms[loanId];
    }

    private EditContext GetBindingPeriodEditContext(Guid loanId)
    {
        EnsureLoanForms(loanId);
        return bindingPeriodEditContexts[loanId];
    }

    private void EnsureLoanForms(Guid loanId)
    {
        if (!bindingPeriodForms.ContainsKey(loanId))
        {
            bindingPeriodForms[loanId] = CreateBindingPeriodForm();
            bindingPeriodEditContexts[loanId] = new EditContext(bindingPeriodForms[loanId]);
        }

    }

    private static LoanBindingPeriodFormModel CreateBindingPeriodForm()
    {
        var today = DateTime.Today;
        return new LoanBindingPeriodFormModel
        {
            StartDate = new DateTime(today.Year, today.Month, 1),
            EndDate = new DateTime(today.Year, today.Month, 1)
        };
    }

    private IReadOnlyList<LoanInterestBindingPeriod> GetLoanInterestBindingPeriods(Guid loanId) =>
        AppState.Data.LoanInterestBindingPeriods
            .Where(period => period.LoanId == loanId)
            .OrderBy(period => period.StartMonth)
            .ThenBy(period => period.EndMonth)
            .ToList();

    private IReadOnlyList<MonthlyBalance> GetBalanceEntries(Guid entityId) =>
        AppState.GetMonthlyBalances(entityId);

    private IReadOnlyList<string> GetSubcategorySuggestions() =>
        AppState.Data.ExpenseRecords
            .Where(record => record.Category == ExpenseCategory.Transport && !string.IsNullOrWhiteSpace(record.Subcategory))
            .Select(record => record.Subcategory.Trim())
            .Concat(AppState.Data.TransportDefinitions
                .Where(record => !string.IsNullOrWhiteSpace(record.Subcategory))
                .Select(record => record.Subcategory.Trim()))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(value => value)
            .ToList();

    private string GetIntervalLabel(int intervalMonths)
    {
        return intervalMonths switch
        {
            1 => Localizer["interval.monthly"],
            3 => Localizer["interval.quarterly"],
            6 => Localizer["interval.semiAnnual"],
            12 => Localizer["interval.yearly"],
            _ => string.Format(Localizer["transport.intervalFallback"], intervalMonths)
        };
    }

    private string GetMonthYearLabel(int year, int month) => $"{Localizer[$"month.{month}"]} {year}";

    private static string FormatDate(DateOnly date) => date.ToString("yyyy-MM-dd");

    private static string FormatInterestRate(decimal rate) => $"{rate:0.##}%";

    private string GetDefinitionDisplay(TransportCostDefinition definition)
    {
        var vehicleName = GetVehicleName(definition.VehicleId);
        var subcategory = AppState.GetExpenseLabelDisplay(definition.Subcategory);
        return string.IsNullOrWhiteSpace(vehicleName)
            ? subcategory
            : $"{vehicleName} - {subcategory}";
    }

    private string GetVehicleName(Guid? vehicleId)
    {
        if (!vehicleId.HasValue)
        {
            return string.Empty;
        }

        return TransportVehicles.FirstOrDefault(vehicle => vehicle.Id == vehicleId.Value)?.Name ?? string.Empty;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AppState.Changed -= HandleChanged;
        Localizer.Changed -= HandleChanged;
    }

